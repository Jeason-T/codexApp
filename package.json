{
  "name": "fanqie-uploader",
  "version": "1.1.20",
  "private": true,
  "description": "番茄章节批量上传助手 - Electron + Vue3 desktop MVP",
  "author": "Local Author",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "start": "electron .",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "chardet": "^2.1.1",
    "iconv-lite": "^0.7.2",
    "mammoth": "^1.12.0",
    "playwright": "^1.60.0",
    "sql.js": "^1.14.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^6.2.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.local.fanqie.uploader",
    "productName": "番茄章节批量上传助手",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "src/services/fileParser.js",
      "src/services/database.js",
      "src/services/fanqieUploader.js",
      "src/services/fanqieSelectors.js",
      "src/services/logger.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "logs",
        "to": "logs",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
